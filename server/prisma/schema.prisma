generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String
  password             String
  isAdmin              Boolean              @default(false)
  favorites            Favorite[]
  cocktails            Cocktail[]           @relation("CreatedBy")
  notes                Note[]
  replies              Reply[]
  pushSubscriptions    PushSubscription[]
  bourbons             Bourbon[]            @relation("BourbonCreatedBy")
  bourbonRatings       BourbonRating[]      @relation("BourbonRatingCreatedBy")
  bourbonReviewReplies BourbonReviewReply[] @relation("BourbonReviewReplyCreatedBy")
  wines                Wine[]               @relation("WineCreatedBy")
  wineRatings          WineRating[]         @relation("WineRatingCreatedBy")
  wineReviewReplies    WineReviewReply[]    @relation("WineReviewReplyCreatedBy")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
}

model Cocktail {
  id          String       @id @default(cuid())
  name        String
  glassware   String
  directions  String
  imageUrl    String?
  ingredients Ingredient[]
  favorites   Favorite[]
  tags        Tag[]
  createdBy   User         @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  cocktails Cocktail[]
  createdAt DateTime   @default(now())
}

model Ingredient {
  id         String   @id @default(cuid())
  name       String
  volume     String
  cocktail   Cocktail @relation(fields: [cocktailId], references: [id], onDelete: Cascade)
  cocktailId String
}

model Favorite {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  cocktail   Cocktail @relation(fields: [cocktailId], references: [id], onDelete: Cascade)
  cocktailId String
  createdAt  DateTime @default(now())

  @@unique([userId, cocktailId])
}

model Note {
  id          String   @id @default(cuid())
  content     String
  imageUrl    String?
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  replies     Reply[]
  createdAt   DateTime @default(now())
}

model Reply {
  id          String   @id @default(cuid())
  content     String
  imageUrl    String?
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId      String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime @default(now())
}

model Bourbon {
  id                String          @id @default(cuid())
  name              String
  locationPurchased String
  createdBy         User            @relation("BourbonCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById       String
  ratings           BourbonRating[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model BourbonRating {
  id          String               @id @default(cuid())
  stars       Int
  review      String?
  bourbon     Bourbon              @relation(fields: [bourbonId], references: [id], onDelete: Cascade)
  bourbonId   String
  createdBy   User                 @relation("BourbonRatingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  replies     BourbonReviewReply[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([bourbonId, createdById])
}

model BourbonReviewReply {
  id          String        @id @default(cuid())
  content     String
  rating      BourbonRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  ratingId    String
  createdBy   User          @relation("BourbonReviewReplyCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime      @default(now())
}

model Wine {
  id                String       @id @default(cuid())
  name              String
  locationPurchased String
  createdBy         User         @relation("WineCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById       String
  ratings           WineRating[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model WineRating {
  id          String            @id @default(cuid())
  stars       Int
  review      String?
  wine        Wine              @relation(fields: [wineId], references: [id], onDelete: Cascade)
  wineId      String
  createdBy   User              @relation("WineRatingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  replies     WineReviewReply[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([wineId, createdById])
}

model WineReviewReply {
  id          String     @id @default(cuid())
  content     String
  rating      WineRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  ratingId    String
  createdBy   User       @relation("WineReviewReplyCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime   @default(now())
}
